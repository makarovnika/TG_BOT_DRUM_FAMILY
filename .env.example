# Скопируй этот файл в `.env` и заполни значения.
# `.env` НЕ коммитится (он в .gitignore).

# === Telegram ===
BOT_TOKEN=

# === YClients ===
# Партнёрский токен — идентификатор твоего приложения в YClients.
# Берётся на developers.yclients.com → твоё приложение → «Общая информация».
YCLIENTS_PARTNER_TOKEN=

# User token — два варианта (нужен ОДИН из них).
#
# Вариант A (рекомендуется): статический User Token системного пользователя.
# Берётся на developers.yclients.com → твоё приложение → «Доступ к API».
# Не протухает, не требует логина/пароля админа.
YCLIENTS_USER_TOKEN=
#
# Вариант B (legacy): логин/пароль админа YClients. Бот сам получит user_token
# через POST /auth. Используется, если статический токен недоступен.
YCLIENTS_USER_LOGIN=
YCLIENTS_USER_PASSWORD=

# ID филиала и формы записи — видны в URL админки YClients.
YCLIENTS_COMPANY_ID=
YCLIENTS_FORM_ID=

# === Прочее ===
DATABASE_URL=sqlite+aiosqlite:///./bot.db
LOG_LEVEL=INFO
# Telegram-ID администраторов через запятую (для будущих админ-команд).
# Узнать свой Telegram-ID можно у @userinfobot.
ADMIN_TELEGRAM_IDS=
